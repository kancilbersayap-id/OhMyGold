# ─── E2E Test Credentials ────────────────────────────────────────────────────
#
# Copy these into .env.local and fill in real values.
# Create both test users in your Supabase project (Auth → Users → Invite user
# or via the Supabase dashboard). Use a separate Supabase project or a
# dedicated test schema — never run E2E tests against production user data.
#
# User A must exist and will have test holdings + buyback prices inserted by
# auth.setup.js before each run. Any pre-existing data for User A is deleted.
#
# User B must exist and must have zero holdings and zero buyback prices.
# auth.setup.js will clean any leftover data for User B before each run.

TEST_USER_A_EMAIL=user-a@yourtestemail.com
TEST_USER_A_PASSWORD=your-strong-password-a

TEST_USER_B_EMAIL=user-b@yourtestemail.com
TEST_USER_B_PASSWORD=your-strong-password-b

# ─── Supabase connection (already in .env.local for the app) ─────────────────
# These are read by tests/helpers/db.js for admin seeding operations.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are already set.
# SUPABASE_ADMIN_KEY (service role key) is already set.
# No extra values needed — just add the TEST_USER_* vars above.
