{
  "color": {
    "background": {
      "$type": "color",
      "$value": "#ffffff",
      "$description": "Page background (light mode). Dark mode: #000000"
    },
    "background-2": {
      "$type": "color",
      "$value": "#fafafa",
      "$description": "Subtle/secondary background, section breaks. Dark mode: #0a0a0a"
    },
    "text": {
      "$type": "color",
      "$value": "#171717",
      "$description": "Primary text color. Dark mode: #ededed"
    },
    "text-muted": {
      "$type": "color",
      "$value": "#4d4d4d",
      "$description": "Secondary/muted text, labels, captions. Dark mode: #a1a1a1"
    },
    "primary": {
      "$type": "color",
      "$value": "#bd5200",
      "$description": "Brand amber/gold — accent, highlights, focus states"
    },
    "secondary": {
      "$type": "color",
      "$value": "#0070f3",
      "$description": "Brand blue — links, secondary actions"
    },
    "accent": {
      "$type": "color",
      "$value": "#0096ff",
      "$description": "Sky blue — hover/active states, chart accents"
    },
    "border": {
      "$type": "color",
      "$value": "#d1d5db",
      "$description": "Borders, dividers, input outlines. Dark mode: #1f1f1f"
    },
    "success": {
      "$type": "color",
      "$value": "#22c55e",
      "$description": "Positive states — gains, increases, confirmations"
    },
    "success-bg": {
      "$type": "color",
      "$value": "rgba(34, 197, 94, 0.15)",
      "$description": "Tinted background for success badges/banners"
    },
    "danger": {
      "$type": "color",
      "$value": "#ef4444",
      "$description": "Negative states — losses, decreases, errors, destructive actions"
    },
    "danger-bg": {
      "$type": "color",
      "$value": "rgba(239, 68, 68, 0.15)",
      "$description": "Tinted background for danger badges/banners"
    },
    "chart-blue": {
      "$type": "color",
      "$value": "#52AEFF",
      "$description": "Chart line/series color"
    },
    "popover-bg": {
      "$type": "color",
      "$value": "#0a0a0a",
      "$description": "Popover/dropdown background (dark surface)"
    },
    "popover-hover": {
      "$type": "color",
      "$value": "#1a1a1a",
      "$description": "Popover/dropdown item hover state"
    }
  },
  "typography": {
    "heading-1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "48px",
        "fontWeight": 600,
        "lineHeight": "48px",
        "letterSpacing": "-2.28px"
      },
      "$description": "Page titles (use once per page)"
    },
    "heading-2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "14px",
        "fontWeight": 500,
        "lineHeight": "20px",
        "letterSpacing": "-0.28px"
      },
      "$description": "Section headings, card titles"
    },
    "heading-3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "32px",
        "fontWeight": 600,
        "lineHeight": "40px",
        "letterSpacing": "-1.28px"
      },
      "$description": "Sub-section headings, metric values"
    },
    "heading-4": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "24px",
        "fontWeight": 600,
        "lineHeight": "32px",
        "letterSpacing": "-0.96px"
      },
      "$description": "Mid-size headings (between heading-3 and heading-5)"
    },
    "heading-5": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": "20px",
        "letterSpacing": "normal"
      },
      "$description": "Minor headings, labels"
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": "normal",
        "letterSpacing": "normal"
      },
      "$description": "Default body/paragraph text"
    },
    "body-text": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": "16px",
        "letterSpacing": "normal"
      },
      "$description": "Secondary text, descriptions"
    },
    "inline-text": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": "14px",
        "letterSpacing": "normal"
      },
      "$description": "Inline text elements, captions"
    },
    "link": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": "normal",
        "letterSpacing": "normal"
      },
      "$description": "Hyperlinks"
    },
    "button": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "14px",
        "fontWeight": 500,
        "lineHeight": "14px",
        "letterSpacing": "normal"
      },
      "$description": "Button labels"
    },
    "navigation": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": "normal",
        "letterSpacing": "normal"
      },
      "$description": "Navigation items"
    },
    "modal-title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-geist-sans), Arial, sans-serif",
        "fontSize": "20px",
        "fontWeight": 600,
        "lineHeight": "24px",
        "letterSpacing": "-0.47px"
      },
      "$description": "Modal/dialog titles"
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "var(--font-mono), 'Courier New', monospace",
        "fontSize": "28px",
        "fontWeight": 400,
        "lineHeight": "1.2",
        "letterSpacing": "-0.5px"
      },
      "$description": "Monospace numerical displays (metric values, prices)"
    }
  },
  "spacing": {
    "3xs": {
      "$type": "dimension",
      "$value": "4px",
      "$description": "Hairline gap (standardised from .03889em to 4px). Currently unused — reserved for future micro-spacing"
    },
    "2xs": {
      "$type": "dimension",
      "$value": "14px",
      "$description": "Tight gap, base unit for calc() ratios across the app"
    },
    "xs": {
      "$type": "dimension",
      "$value": "30px",
      "$description": "Standard component padding/gap"
    },
    "sm": {
      "$type": "dimension",
      "$value": "52px",
      "$description": "Section margins"
    },
    "md": {
      "$type": "dimension",
      "$value": "80px",
      "$description": "Major section spacing"
    },
    "lg": {
      "$type": "dimension",
      "$value": "110px",
      "$description": "Large section breaks"
    },
    "xl": {
      "$type": "dimension",
      "$value": "8rem",
      "$description": "Layout grid gap (~128px)"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "160px",
      "$description": "Hero section spacing"
    },
    "3xl": {
      "$type": "dimension",
      "$value": "11rem",
      "$description": "Extra-large layout gap (~176px)"
    },
    "4xl": {
      "$type": "dimension",
      "$value": "12rem",
      "$description": "Very large layout gap (~192px)"
    },
    "5xl": {
      "$type": "dimension",
      "$value": "13rem",
      "$description": "Hero/landing spacing (~208px)"
    },
    "6xl": {
      "$type": "dimension",
      "$value": "16rem",
      "$description": "Page-level vertical rhythm (~256px)"
    }
  },
  "borderRadius": {
    "none": {
      "$type": "dimension",
      "$value": "0",
      "$description": "Square edges. Aligned to Tailwind v3: rounded-none."
    },
    "sm": {
      "$type": "dimension",
      "$value": "0.125rem",
      "$description": "2px. Tight borders, badges. Aligned to Tailwind v3: rounded-sm."
    },
    "md": {
      "$type": "dimension",
      "$value": "0.375rem",
      "$description": "6px. Standard — buttons, cards, inputs. Aligned to Tailwind v3: rounded-md."
    },
    "lg": {
      "$type": "dimension",
      "$value": "0.5rem",
      "$description": "8px. Prominent cards, popovers. Aligned to Tailwind v3: rounded-lg."
    },
    "xl": {
      "$type": "dimension",
      "$value": "0.75rem",
      "$description": "12px. Modals, hero cards. Aligned to Tailwind v3: rounded-xl."
    },
    "2xl": {
      "$type": "dimension",
      "$value": "1rem",
      "$description": "16px. Aligned to Tailwind v3: rounded-2xl."
    },
    "3xl": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "24px. Aligned to Tailwind v3: rounded-3xl."
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px",
      "$description": "Pills, avatars, circular buttons. Aligned to Tailwind v3: rounded-full."
    }
  },
  "state": {
    "opacity-hover": {
      "$type": "number",
      "$value": 0.85,
      "$description": "Hover state opacity for interactive elements"
    },
    "opacity-active": {
      "$type": "number",
      "$value": 0.7,
      "$description": "Active/pressed state opacity"
    },
    "opacity-disabled": {
      "$type": "number",
      "$value": 0.5,
      "$description": "Disabled state opacity"
    },
    "transition-fast": {
      "$type": "duration",
      "$value": "0.12s",
      "$description": "Quick UI feedback (button press, hover)"
    },
    "transition-base": {
      "$type": "duration",
      "$value": "0.15s",
      "$description": "Standard transitions (color, opacity)"
    },
    "transition-slow": {
      "$type": "duration",
      "$value": "0.2s",
      "$description": "Slower transitions (badges, complex state)"
    }
  }
}
